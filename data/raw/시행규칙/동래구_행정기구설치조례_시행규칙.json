      "조문번호": [
        "000200",
        "000200"
      ],
      "조제목": "직무",
      "조내용": "제2조(직무) 국장 및 실장은 부구청장을, 과장은 국장을 보좌하고, 소속 직원을 지휘·감독한다.",
      "조문여부": "Y"
    },
